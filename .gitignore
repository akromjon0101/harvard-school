# ── Dependencies ─────────────────────────────────────────────────────
node_modules
backend/node_modules

# ── Build output ──────────────────────────────────────────────────────
dist
dist-ssr
build
.vite

# ── Environment variables — NEVER commit these ────────────────────────
.env
.env.local
.env.development
.env.production
.env.test
backend/.env
backend/.env.*

# ── User-generated uploads (served at runtime, not tracked in git) ────
backend/uploads/*
!backend/uploads/.gitkeep

# ── Logs ─────────────────────────────────────────────────────────────
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS files ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor files ─────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Cache ─────────────────────────────────────────────────────────────
.cache
.eslintcache
*.tsbuildinfo

# ── Database dumps ────────────────────────────────────────────────────
*.sql
*.sqlite
*.db

# ── Claude Code internal ──────────────────────────────────────────────
.claude/
